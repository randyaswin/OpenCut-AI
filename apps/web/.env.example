# Environment variables example
# Copy this file to .env.local and update the values as needed

# Node
NODE_ENV=development

# Public
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_MARBLE_API_URL=https://api.marblecms.com

# Google Analytics (optional — leave blank to disable)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# AI Backend — the FastAPI service running at services/ai-backend
# Starts automatically with `docker compose up` or `python run.py` in services/ai-backend
NEXT_PUBLIC_AI_BACKEND_URL=http://localhost:8420

# Server
DATABASE_URL="postgresql://opencut:opencut@localhost:5432/opencut"
BETTER_AUTH_SECRET=your_better_auth_secret

UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=example_token

MARBLE_WORKSPACE_KEY=your_workspace_key_here

FREESOUND_CLIENT_ID=your_client_id_here
FREESOUND_API_KEY=your_api_key_here

CLOUDFLARE_ACCOUNT_ID=your_account_id_here
R2_ACCESS_KEY_ID=your_access_key_here
R2_SECRET_ACCESS_KEY=your_secret_key_here
R2_BUCKET_NAME=opencut-transcription # whatever you named your r2 bucket

MODAL_TRANSCRIPTION_URL=your_modal_url_here

# ---------------------
# AI Backend Environment Variables (for services/ai-backend/.env)
# These are only needed if running the AI backend outside Docker.
# Inside Docker they are set via docker-compose.yml.
# ---------------------
# OPENCUTAI_HOST=0.0.0.0
# OPENCUTAI_PORT=8420
# OPENCUTAI_OLLAMA_URL=http://localhost:11434
# OPENCUTAI_OLLAMA_DEFAULT_MODEL=llama3.2
# OPENCUTAI_WHISPER_MODEL_SIZE=base        # tiny, base, small, medium, large-v3
# OPENCUTAI_WHISPER_DEVICE=auto            # auto, cpu, cuda
# OPENCUTAI_WHISPER_COMPUTE_TYPE=int8      # int8, float16, float32
# OPENCUTAI_SILENCE_THRESHOLD_DB=-30.0
# OPENCUTAI_MAX_UPLOAD_SIZE=524288000      # 500 MB

# Sarvam AI — Indian language APIs (speech-to-text, translation, TTS)
# Get your key at https://dashboard.sarvam.ai
# Supports 22 Indian languages: Hindi, Bengali, Tamil, Telugu, Marathi, etc.
# Can also be set in Settings > API Keys in the editor UI.
NEXT_PUBLIC_SARVAM_API_KEY=your_sarvam_api_key_here

# ---------------------
# AI Video Generation API Keys
# Can also be set in Settings > API Keys in the editor UI.
# ---------------------

# Replicate — access Runway Gen-3, Pika, Kling, MiniMax, Stable Video & 10+ more models
# Get your token at https://replicate.com ($5 free credits on signup)
NEXT_PUBLIC_REPLICATE_API_TOKEN=

# Seedance 2.0 (ByteDance) via PiAPI — high quality text-to-video up to 15s
# Get your key at https://piapi.ai
NEXT_PUBLIC_SEEDANCE_API_KEY=

# Stability AI — Stable Video Diffusion and future video models
# Get your key at https://platform.stability.ai
NEXT_PUBLIC_STABILITY_API_KEY=

# Luma AI — Dream Machine for realistic motion and camera control
# Get your key at https://lumalabs.ai/dream-machine
NEXT_PUBLIC_LUMA_API_KEY=

# Smallest AI — Lightning TTS (15 languages) & Pulse STT (39 languages)
# Get your key at https://app.smallest.ai
NEXT_PUBLIC_SMALLEST_API_KEY=