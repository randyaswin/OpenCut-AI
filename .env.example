CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k
HF_TOKEN=

# --- API Keys ---
SARVAM_API_KEY=
SMALLEST_API_KEY=
SEEDANCE_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_KEY=
